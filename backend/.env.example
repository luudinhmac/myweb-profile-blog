# Application
NODE_ENV=development
PORT=3001

# Database Configuration (PostgreSQL - Required for Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://staging_user:admin@localhost:5432/portfolio_db?schema=public"

# Security
JWT_SECRET=generate_a_random_32_char_string_here
ALLOWED_ORIGINS=http://localhost:3000,http://staging.local,https://your-domain.com

# Initial Admin Credentials (Optional - Used for seeding)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_secret_password
