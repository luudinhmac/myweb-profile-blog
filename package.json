{
  "name": "portfolio-monolith-standalone",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --prefix backend start:dev\" \"pnpm --prefix frontend dev\"",
    "backend": "pnpm --prefix backend start:dev",
    "frontend": "pnpm --prefix frontend dev",
    "install:all": "pnpm --prefix backend install && pnpm --prefix frontend install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
