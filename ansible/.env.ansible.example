# --- Ansible Deployment Environment Variables ---

# [Common SSH Configuration]
# STAGING_IP=192.168.1.100        # IP of the staging server
# STAGING_USER=macld              # SSH user for staging
# STAGING_SSH_KEY_PATH=~/.ssh/id_rsa

PROD_IP=1.2.3.4                   # IP of the production VPS
PROD_USER=root                    # SSH user for production
PROD_SSH_KEY_PATH=~/.ssh/vps_key  # Path to the private key for production

# [Staging Environment Variables]
STAGING_DB_USER=staging_user
STAGING_DB_PASSWORD=your_staging_db_pass
STAGING_DB_NAME=portfolio_staging
STAGING_DOMAIN=staging.local

# [Production Environment Variables]
PROD_DB_USER=prod_user
PROD_DB_PASSWORD=your_prod_db_pass
PROD_DB_NAME=portfolio_prod
PROD_DOMAIN=yourdomain.com
CERT_EMAIL=admin@yourdomain.com

# --- How to use ---
# 1. Copy this file to .env.ansible
# 2. Export the variables or use them in your CI/CD runner:
#    export $(cat .env.ansible | xargs)
# 3. Run the playbook:
#    ansible-playbook -i inventory.ini playbooks/production.yml
