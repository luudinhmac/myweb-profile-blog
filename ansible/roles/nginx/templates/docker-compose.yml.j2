services:
  postgres:
    image: postgres:16.13-alpine
    container_name: portfolio-db
    restart: always
    environment:
      POSTGRES_USER: {{ db_user }}
      POSTGRES_PASSWORD: {{ db_password }}
      POSTGRES_DB: {{ db_name }}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - portfolio-network

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: portfolio-backend
    restart: always
    expose:
      - "3001"
    environment:
      - DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@postgres:5432/{{ db_name }}
      - JWT_SECRET={{ jwt_secret }}
      - PORT=3001
      - NODE_ENV=production
    depends_on:
      - postgres
    volumes:
      - uploads_data:/app/uploads
    networks:
      - portfolio-network

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: portfolio-frontend
    restart: always
    expose:
      - "3000"
    environment:
      - INTERNAL_API_URL=http://backend:3001/api
      - NODE_ENV=production
    depends_on:
      - backend
    networks:
      - portfolio-network

  nginx:
    image: nginx:alpine
    container_name: portfolio-nginx
    restart: always
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro
{% if ssl_method == 'letsencrypt' %}
      - /etc/letsencrypt:/etc/letsencrypt:ro
{% else %}
      - ./nginx/ssl:/etc/nginx/ssl:ro
{% endif %}
    depends_on:
      - frontend
      - backend
    networks:
      - portfolio-network

networks:
  portfolio-network:
    driver: bridge

volumes:
  postgres_data:
  uploads_data:
