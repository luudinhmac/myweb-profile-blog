# Application Environment
NODE_ENV={{ env_name }}
PORT=3001

# Database Configuration (Native on VM)
# We use 172.17.0.1 (Docker Bridge Default Gateway) to access host services
DB_HOST=172.17.0.1
DB_PORT=5432
DB_USER={{ db_user | default('macld') }}
DB_PASSWORD={{ db_password | default('macld@2026') }}
DB_NAME={{ db_name }}

# Prisma Connection String (Crucial)
DATABASE_URL="postgresql://{{ db_user | default('macld') }}:{{ db_password | default('macld@2026') }}@172.17.0.1:5432/{{ db_name }}"

# Security
JWT_SECRET={{ jwt_secret | default('super_secret_jwt_key_2026') }}
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://{{ domain_name }},https://{{ domain_name }}
